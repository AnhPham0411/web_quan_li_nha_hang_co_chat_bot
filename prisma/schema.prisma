generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================

enum Role {
  ADMIN
  STAFF
  CUSTOMER

  @@map("user_role")
}

enum TableStatus {
  EMPTY
  BOOKED
  SERVING
  CLEANING

  @@map("table_status")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW

  @@map("reservation_status")
}

// =============================================
// MODELS
// =============================================

model User {
  id           String   @id @default(uuid())
  role         Role     @default(STAFF)
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reservations Reservation[]
  passwordResetTokens PasswordResetToken[]
  shifts              Shift[]
  pushSubscriptions   PushSubscription[]
  orders              Order[]

  @@map("user")
}

/// Thực đơn quán ăn
/// 🚨 PM FIX: Dùng stockQuantity (Int) thay vì isAvailable (Boolean)
/// Với các món Signature như Bò Wagyu cần kiểm soát số lượng chính xác
model MenuItem {
  id            String   @id @default(uuid())
  name          String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?  @db.Text
  category      String   @default("Món chính")
  stockQuantity Int      @default(10)
  isAvailable   Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderItems    OrderItem[]

  @@map("menu_item")
}

/// Bàn ăn
/// 🚨 PM FIX: 4 trạng thái thay vì 3 — thêm CLEANING để tránh trải nghiệm tồi
/// 🚨 PM FIX: lockedUntil để soft-lock tránh race condition (đặt bàn trùng)
model Table {
  id           String        @id @default(uuid())
  tableNumber  Int           @unique
  capacity     Int
  status       TableStatus   @default(EMPTY)
  lockedUntil  DateTime?
  notes        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reservations   Reservation[]
  orders         Order[]

  @@map("table")
}

/// Đặt bàn
/// 🚨 PM FIX: status mặc định PENDING — không bao giờ để AI tự confirm booking
/// 🚨 PM FIX: lockedUntil — hold bàn 5 phút khi Bot gợi ý, tránh double booking
model Reservation {
  id          String            @id @default(uuid())
  tableId     String?
  guestName   String
  guestPhone  String
  partySize   Int
  notes       String?           @db.Text
  source      String            @default("website") // "website" | "chatbot" | "walkin"
  status      ReservationStatus @default(PENDING)
  lockedUntil DateTime?
  reservedAt  DateTime
  confirmedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  table       Table?            @relation(fields: [tableId], references: [id])
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])

  @@index([tableId])
  @@index([userId])
  @@map("reservation")
}

// =============================================
// NEW MODELS FOR PHASE 1 & 4
// =============================================

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_token")
}

model Order {
  id             String      @id @default(uuid())
  tableId        String
  userId         String?
  status         OrderStatus @default(PENDING)
  notes          String?     @db.Text
  
  // Voucher & Pricing
  voucherId      String?
  voucher        Voucher?    @relation(fields: [voucherId], references: [id])
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  totalPrice     Decimal?    @db.Decimal(10, 2) // Total after discount

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  table          Table       @relation(fields: [tableId], references: [id])
  user           User?       @relation(fields: [userId], references: [id])
  items          OrderItem[]
  review         Review?

  @@map("order")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  notes      String?
  createdAt  DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_item")
}

model Shift {
  id        String   @id @default(uuid())
  staffId   String
  date      DateTime @db.Date
  startTime DateTime
  endTime   DateTime
  notes     String?
  createdAt DateTime @default(now())

  staff User @relation(fields: [staffId], references: [id])

  @@map("shift")
}

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String?
  p256dhKey    String
  authKey      String
  createdAt    DateTime @default(now())
  
  user         User?    @relation(fields: [userId], references: [id])

  @@map("push_subscription")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SERVED
  CANCELLED
  PAID

  @@map("order_status")
}

// =============================================
// NEW MODELS FOR PHASE 4 (Vouchers & Reviews)
// =============================================

enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT

  @@map("voucher_type")
}

model Voucher {
  id             String      @id @default(uuid())
  code           String      @unique
  discountType   VoucherType @default(PERCENTAGE)
  value          Decimal     @db.Decimal(10, 2)
  minOrderAmount Decimal?    @db.Decimal(10, 2)
  startDate      DateTime    @default(now())
  endDate        DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  orders         Order[]

  @@map("voucher")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique
  rating    Int      @default(5)
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("review")
}
